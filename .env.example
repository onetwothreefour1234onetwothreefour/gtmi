# Anthropic
ANTHROPIC_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Trigger.dev
TRIGGER_SECRET_KEY=

# Database (Supabase pooler URL — required by all DB clients and scripts)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Scraper service
# Local dev: http://localhost:8765
# Cloud (Google Cloud Run): https://gtmi-scraper-<hash>-<region>.a.run.app
SCRAPER_URL=http://localhost:8765
