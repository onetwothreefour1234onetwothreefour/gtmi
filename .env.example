# Anthropic
ANTHROPIC_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Trigger.dev
TRIGGER_SECRET_KEY=

# Database (Supabase transaction pooler URL — port 6543, used by all
# runtime DB clients and scripts).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Direct connection (port 5432) for DDL / migrations. Same host as
# DATABASE_URL but different port to bypass transaction pooler.
DIRECT_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public keys for Next.js browser/SSR auth (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Scraper service URL.
# Cloud Run (production): https://gtmi-scraper-72324018663.europe-west1.run.app
#   Auth: user identity token via gcloud auth print-identity-token (Option B).
#   The developer's gcloud user account must have roles/run.invoker on
#   the gtmi-scraper service. scrape.ts injects the Bearer header
#   automatically when SCRAPER_URL starts with https://.
#   Long-term: upgrade to service account impersonation (Option A) —
#   requires gtmi-canary-runner SA with roles/run.invoker +
#   roles/iam.serviceAccountTokenCreator granted to the developer user.
#   See docs/decisions/017-scraper-auth-upgrade-path.md when created.
# Local dev: http://localhost:8765 (no auth required)
SCRAPER_URL=

# Phase 3 pipeline flags
# PHASE3_VDEM_ENABLED defaults to TRUE (set to 'false' to disable). The
# methodology requires E.3.1 (Rule of Law) per METHODOLOGY.md §7.5;
# disabling this flag returns E.3.1 to the LLM extraction batch and it
# will be empty for ABSENT countries. Phase 3.6 / Fix A / Q5 decision.
PHASE3_VDEM_ENABLED=true
# PHASE3_DISCOVERY_V2 / PHASE3_TIER2_FALLBACK default to false (set to
# 'true' to enable). Cross-departmental discovery v2 (Phase 3.2) and the
# Tier 2 fallback path (ADR-013) are still opt-in.
PHASE3_DISCOVERY_V2=false
PHASE3_TIER2_FALLBACK=false
# Phase 3.9 / W12 — surgical re-run modes are passed via
#   --mode {full,discover-only,narrow,gate-failed,rubric-changed,field,archive-first,archive-only}
# (no env-flag equivalent any more). The legacy PHASE3_TARGETED_RERUN
# env var was removed in Phase 3.10.

# Cost guards
# MAX_RERUN_COST_USD (default 5) — per-canary-invocation upfront cap.
# Throws and refuses to proceed when the projected cost across all
# CANARY_TARGETS exceeds the cap. --confirm-cost overrides.
MAX_RERUN_COST_USD=5
# MAX_COST_PER_PROGRAM_USD (default 1.5) — per-programme upfront cap
# (Phase 3.10). Aborts THIS programme without throwing so a multi-
# programme batch keeps moving on to the next target. --confirm-cost
# overrides. Useful in cohort runs where one bad-discovery programme
# could otherwise consume most of the batch budget.
MAX_COST_PER_PROGRAM_USD=1.5